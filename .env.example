# Copy to .env before deploying:
#   cp .env.example .env

NODE_ENV=production
PORT=5000
# Public HTTP port on the host (80 on EC2; use 8080 if 80 is busy locally)
HOST_PORT=80

# Public browser origin (EC2 public IP or domain). Comma-separate multiple.
# Example: http://13.232.xx.xx  or  https://voltview.example.com
CLIENT_URL=http://localhost

# Mongo — docker-compose overrides this to mongodb://mongo:27017/voltview
MONGO_URI=mongodb://127.0.0.1:27017/voltview

# REQUIRED in production — use long random strings
JWT_ACCESS_SECRET=replace-with-a-long-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-refresh-secret
JWT_RESET_SECRET=replace-with-a-long-reset-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Demo energy simulator (set false to disable)
ENABLE_ENERGY_SIMULATION=true

# Optional SMTP for password reset emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="VoltView <no-reply@voltview.local>"
